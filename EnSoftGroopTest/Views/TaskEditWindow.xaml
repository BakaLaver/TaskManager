<Window x:Class="EnSoftGroopTest.Views.TaskEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EnSoftGroopTest.Views"
        xmlns:models="clr-namespace:EnSoftGroopTest.Models"
        mc:Ignorable="d"
        Title="Редактирование задачи" Height="350" Width="400"
        WindowStartupLocation="CenterOwner" WindowStyle="ToolWindow"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Название -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Название:" 
                   VerticalAlignment="Center" Margin="0,0,10,10"/>
        <TextBox Grid.Row="0" Grid.Column="1" Height="25" Margin="0,0,0,10"
                 Text="{Binding Task.Title, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                 Validation.ErrorTemplate="{x:Null}"/>

        <!-- Описание -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Описание:" 
                   VerticalAlignment="Top" Margin="0,0,10,10"/>
        <TextBox Grid.Row="1" Grid.Column="1" Height="60" Margin="0,0,0,10"
                 Text="{Binding Task.Description, UpdateSourceTrigger=PropertyChanged}"
                 TextWrapping="Wrap" AcceptsReturn="True"/>

        <!-- Приоритет -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Приоритет:" 
                   VerticalAlignment="Center" Margin="0,0,10,10"/>
        <ComboBox Grid.Row="2" Grid.Column="1" Height="25" Margin="0,0,0,10"
                  SelectedItem="{Binding Task.Priority}">
            <models:TaskPriority>Low</models:TaskPriority>
            <models:TaskPriority>Medium</models:TaskPriority>
            <models:TaskPriority>High</models:TaskPriority>
        </ComboBox>

        <!-- Дата выполнения -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Срок:" 
                   VerticalAlignment="Center" Margin="0,0,10,10"/>
        <DatePicker Grid.Row="3" Grid.Column="1" Height="25" Margin="0,0,0,10"
                    SelectedDate="{Binding Task.DueDate, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" 
                    Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Сохранить" Width="80" Height="30" Margin="0,0,10,0"
                    Command="{Binding SaveCommand}"/>
            <Button Content="Отмена" Width="80" Height="30" 
                    Command="{Binding CancelCommand}"/>
        </StackPanel>

        <!-- Ошибки валидации -->
        <TextBlock Grid.Row="5" Grid.ColumnSpan="2" 
                   Text="{Binding Error}" Foreground="Red"
                   TextWrapping="Wrap" Margin="0,10,0,0"/>
    </Grid>
</Window>
